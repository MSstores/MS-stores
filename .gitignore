package com.msstore;

import org.springframework.boot.SpringApplication;
import org.springframework.boot.autoconfigure.SpringBootApplication;
import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.RestController;

@SpringBootApplication
public class MsStoreApplication {

    public static void main(String[] args) {
        SpringApplication.run(MsStoreApplication.class, args);
    }

    @RestController
    class WebController {

        @GetMapping("/")
        public String home() {
            return """
<!DOCTYPE html>
<html>
<head>
<title>M&S Store</title>

<style>
body{margin:0;font-family:Segoe UI;background:#f5f8fc;}
header{
background:linear-gradient(135deg,#1976d2,#42a5f5);
color:white;
text-align:center;
padding:40px;
}
.products{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
gap:20px;
padding:20px;
}
.card{
background:white;
border-radius:15px;
padding:10px;
box-shadow:0 5px 15px rgba(0,0,0,0.1);
transition:0.3s;
}
.card:hover{transform:scale(1.05);}
img{width:100%;border-radius:10px;}
button{
width:100%;
padding:10px;
border:none;
margin-top:5px;
cursor:pointer;
border-radius:8px;
}
.cartBtn{background:#1976d2;color:white;}
.orderBtn{background:#25D366;color:white;}
</style>

</head>

<body>

<header>
<h1>M&S Store</h1>
<p>Mobile Cases • Perfumes • Accessories</p>
</header>

<div class="products">

<div class="card">
<img src="https://via.placeholder.com/300">
<h3>Luxury Phone Case</h3>
<p>Cases - 39 SAR</p>
<button class="cartBtn" onclick="add('Luxury Phone Case')">Add to Cart</button>
<button class="orderBtn" onclick="order('Luxury Phone Case')">WhatsApp Order</button>
</div>

<div class="card">
<img src="https://via.placeholder.com/300">
<h3>Premium Perfume</h3>
<p>Perfumes - 89 SAR</p>
<button class="cartBtn" onclick="add('Premium Perfume')">Add to Cart</button>
<button class="orderBtn" onclick="order('Premium Perfume')">WhatsApp Order</button>
</div>

<div class="card">
<img src="https://via.placeholder.com/300">
<h3>Wireless Earbuds</h3>
<p>Accessories - 129 SAR</p>
<button class="cartBtn" onclick="add('Wireless Earbuds')">Add to Cart</button>
<button class="orderBtn" onclick="order('Wireless Earbuds')">WhatsApp Order</button>
</div>

</div>

<script>

let cart = [];

function add(item){
cart.push(item);
alert(item + " added to cart");
}

function order(item){
let number = "966508364662";
let msg = encodeURIComponent("Hello, I want to order: " + item);
window.open("https://wa.me/" + number + "?text=" + msg);
}

</script>

</body>
</html>
""";
        }
    }
}